# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# CORS — comma-separated, no trailing slashes
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://createatechhobbies1.vercel.app

# Admin
ADMIN_API_KEY=choose-a-strong-random-string
ADMIN_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# ─── M-Pesa Daraja ────────────────────────────────────────────────────────────
# Get Consumer Key & Secret from https://developer.safaricom.co.ke after
# creating an app and going through the go-live process.

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# ── SANDBOX (testing only) ────────────────────────────────────────────────────
# MPESA_ENVIRONMENT=sandbox
# MPESA_BUSINESS_SHORT_CODE=174379
# MPESA_TILL_NUMBER=174379
# MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# MPESA_CALLBACK_URL=https://<your-ngrok-or-railway>.up.railway.app/api/mpesa/callback/

# ── PRODUCTION (Railway deployment) ──────────────────────────────────────────
# Approved short code from Safaricom go-live. Passkey from approval email.
MPESA_ENVIRONMENT=production
MPESA_BUSINESS_SHORT_CODE=4574069
MPESA_TILL_NUMBER=3434039
MPESA_PASSKEY=your-production-passkey-from-safaricom
MPESA_CALLBACK_URL=https://your-railway-domain.up.railway.app/api/mpesa/callback/
