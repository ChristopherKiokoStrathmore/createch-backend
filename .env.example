# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# CORS — comma-separated, no trailing slashes
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://createatechhobbies1.vercel.app,https://createchhobbies.vercel.app

# Admin
ADMIN_API_KEY=choose-a-strong-random-string
ADMIN_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# M-Pesa is handled by the WooCommerce STK Push plugin on WordPress,
# not by this backend. (Daraja app removed 2026-07.)

# WooCommerce order-mirror webhook — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# and paste the same value into the Woo webhook's Secret field
WOO_WEBHOOK_SECRET=generate-a-strong-random-string

# DPO Pay — get credentials from the DPO merchant portal
DPO_COMPANY_TOKEN=your-dpo-company-token
DPO_SERVICE_ID=your-dpo-service-id
DPO_API_URL=https://secure.3gdirectpay.com/API/v6/
DPO_PAYMENT_URL=https://secure.3gdirectpay.com/payv2.php
DPO_TEST_MODE=True
